# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual token.

# Required: get your token from https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# Optional: webapp login credentials (defaults shown)
APP_USERNAME=admin
APP_PASSWORD=changeme

# Optional: your custom Mapbox style slug (defaults to mapbox/light-v11 if omitted)
# Format: "username/styleId" — find yours at account.mapbox.com/styles
MAPBOX_STYLE=username/styleId

# Optional: port for the upload/render server (default: 3002)
PORT=3002
