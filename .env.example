# Travel Map — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Login credentials for the web app
APP_USERNAME=micha
APP_PASSWORD=your-strong-password-here

# Random secret for session cookies (generate with: openssl rand -hex 32)
SESSION_SECRET=change-this-to-a-random-string

# Optional: override the default port (3002)
# PORT=3002
